    {
        "id": "21f0ffa68878f20d",
        "type": "function",
        "z": "0add0a959b69af8f",
        "name": "thông báo chuyển khoản",
        "func": "let data = msg.payload;\n\n// tạo dữ liệu hiển thị\nlet newData = {\n    sender: data.sender,\n    money: data.money,\n    content: data.content,\n    time: new Date().toLocaleString()\n};\n\n// lưu lịch sử\nlet history = flow.get(\"history\") || [];\nhistory.unshift(newData);\n\nif (history.length > 10) {\n    history.pop();\n}\n\nflow.set(\"history\", history);\n\n// TELEGRAM\nlet telegramMsg = {\n    chatId: \"7851890728\",\n    type: \"message\",\n    content:\n        \"Nhận tiền:\\n\" +\n        \"Người gửi: \" + newData.sender + \"\\n\" +\n        \"Số tiền: \" + newData.money + \" VND\\n\" +\n        \"Nội dung: \" + newData.content\n};\n\n// SOUND (chỉ cần trigger)\nlet soundMsg = { payload: true };\n\n// RETURN 4 OUTPUT\nreturn [\n    { payload: newData },     // output 1 → text\n    { payload: history },     // output 2 → table\n    soundMsg,                 // output 3 → play-soundfile\n    { payload: telegramMsg }  // output 4 → telegram\n];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
